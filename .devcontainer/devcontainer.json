{
  "name": "EVEZ Service Node",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "pip install aiohttp aiosqlite && bash setup.sh || true",
  "forwardPorts": [9100, 9800, 9600],
  "portsAttributes": {
    "9100": { "label": "EVEZ Provider", "onAutoForward": "openPreview" },
    "9800": { "label": "Arena", "onAutoForward": "openPreview" },
    "9600": { "label": "NEUROS", "onAutoForward": "openPreview" }
  }
}
